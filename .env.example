###############################################################################
# portfolio-deploy configuration. Copy to .env and fill in.
#   cp .env.example .env && nano .env
# Then: ./scripts/update.sh
###############################################################################

# ──────────────────────────────────────────────────────────────────────────
# Which apps to run. Comma-separated, no spaces.
#   portfolio      d4m13n.dev (Next.js + PocketBase)
#   mechanicbuddy  MechanicBuddy demo (.NET API + Next.js + management portal)
#   commissions    Commissions app demo (Next.js UI + .NET core-api)
# Caddy is always on regardless. Remove an app here to stop running it.
# ──────────────────────────────────────────────────────────────────────────
COMPOSE_PROFILES=portfolio,mechanicbuddy,commissions

# Email for Let's Encrypt ACME registration / expiry notices.
ACME_EMAIL=damienostler1@outlook.com

# URL scheme. Leave as https for a public host with DNS (Caddy gets real certs).
# For a private/Tailscale host where Let's Encrypt can't validate, set BOTH to
# http (PUBLIC_SCHEME=http and CADDY_SITE_SCHEME=http://) to serve plain HTTP.
PUBLIC_SCHEME=https
CADDY_SITE_SCHEME=

# ──────────────────────────────────────────────────────────────────────────
# Hostnames (DNS A records for all of these must point at this VM).
# The demos live under a separate `demos.d4m13n.dev` zone — a wildcard
# A record `*.demos.d4m13n.dev` covers all the demo subdomains at once.
# ──────────────────────────────────────────────────────────────────────────
# Portfolio
PORTFOLIO_DOMAIN=d4m13n.dev
PORTFOLIO_ORIGIN=https://d4m13n.dev

# MechanicBuddy — the SaaS management portal is the root host; the workshop
# demo app lives under the demo.* subdomain.
MB_MANAGE_HOST=mechanicbuddy.demos.d4m13n.dev            # management portal (root)
MB_WEB_HOST=demo.mechanicbuddy.demos.d4m13n.dev          # workshop demo app (mb-web)
MB_API_HOST=api.mechanicbuddy.demos.d4m13n.dev
MB_MANAGE_API_HOST=manage-api.mechanicbuddy.demos.d4m13n.dev
MB_MAIL_HOST=mail.mechanicbuddy.demos.d4m13n.dev

# Commissions
COMMISSIONS_UI_HOST=commissions.demos.d4m13n.dev
COMMISSIONS_API_HOST=api.commissions.demos.d4m13n.dev

# ──────────────────────────────────────────────────────────────────────────
# Shared PostgreSQL. One container, one volume, a database per app.
# ──────────────────────────────────────────────────────────────────────────
POSTGRES_SUPERUSER=postgres
POSTGRES_PASSWORD=change-me-superuser

# MechanicBuddy single-tenant DB
CARCARE_DB_NAME=carcare
CARCARE_DB_USER=carcare
CARCARE_DB_PASSWORD=change-me-carcare

# MechanicBuddy management/SaaS DB
MB_MANAGEMENT_DB_NAME=mb_management
MB_MANAGEMENT_DB_USER=management
MB_MANAGEMENT_DB_PASSWORD=change-me-mb-management

# Commissions DB
COMMISSIONS_DB_NAME=comissionsapp
COMMISSIONS_DB_USER=comissions
COMMISSIONS_DB_PASSWORD=change-me-comissions

# ──────────────────────────────────────────────────────────────────────────
# MechanicBuddy secrets.
# JWT secrets must be long random strings. Generate with:  openssl rand -hex 32
# ConsumerSecret must match the value the frontend was built with (best-effort
# for the pre-built demo image). After editing these, run ./scripts/setup-secrets.sh
# (update.sh does this for you) to regenerate the mounted appsettings.Secrets.json.
# ──────────────────────────────────────────────────────────────────────────
MB_JWT_SECRET=change-me-mb-jwt-32-chars-minimum-000
MB_CONSUMER_SECRET=change-me-mb-consumer-secret
MB_MGMT_JWT_SECRET=change-me-mb-management-jwt-32-chars-min
MB_PORTAL_SESSION_SECRET=change-me-portal-session-secret
MB_WEB_SESSION_SECRET=change-me-web-session-secret

# MechanicBuddy management billing (optional — leave blank to run without billing)
MB_STRIPE_SECRET_KEY=
MB_STRIPE_WEBHOOK_SECRET=
MB_STRIPE_PUBLISHABLE_KEY=
MB_RESEND_API_KEY=
MB_FROM_EMAIL=noreply@demos.d4m13n.dev

# Set to Development to expose Swagger UI on the .NET APIs (management portal API gates it
# behind Development; keep Production for real deployments).
MB_ASPNETCORE_ENVIRONMENT=Production

# ──────────────────────────────────────────────────────────────────────────
# Commissions app — Auth0 (REQUIRED for login to work).
# In the Auth0 application settings you MUST add the deployed URLs:
#   Allowed Callback URLs:  https://commissions.demos.d4m13n.dev/api/auth/callback
#   Allowed Logout URLs:    https://commissions.demos.d4m13n.dev
#   Allowed Web Origins:    https://commissions.demos.d4m13n.dev
# AUTH0_SECRET is a cookie-encryption key, NOT the client secret: openssl rand -hex 32
# ──────────────────────────────────────────────────────────────────────────
COMMISSIONS_AUTH0_ISSUER_BASE_URL=https://your-tenant.us.auth0.com
COMMISSIONS_AUTH0_DOMAIN=https://your-tenant.us.auth0.com/
COMMISSIONS_AUTH0_CLIENT_ID=
COMMISSIONS_AUTH0_CLIENT_SECRET=
COMMISSIONS_AUTH0_SECRET=change-me-openssl-rand-hex-32
COMMISSIONS_AUTH0_AUDIENCE=https://api.comissions.app
COMMISSIONS_AUTH0_SCOPE="openid profile email read:user write:user read:request write:request read:artist write:artist"

# Commissions app — payments / notifications (optional)
COMMISSIONS_STRIPE_API_KEY=
COMMISSIONS_STRIPE_WEBHOOK_SECRET=
COMMISSIONS_NOVU_API_KEY=

# ──────────────────────────────────────────────────────────────────────────
# Image overrides. Defaults point at the published ghcr.io images; change a
# tag/path here if any image moves. (Portfolio builds from source, not listed.)
# ──────────────────────────────────────────────────────────────────────────
MB_API_IMAGE=ghcr.io/d4m13n-d3v/mechanicbuddy-api:latest
MB_WEB_IMAGE=ghcr.io/d4m13n-d3v/mechanicbuddy-web:latest
MB_DBUP_IMAGE=ghcr.io/d4m13n-d3v/mechanicbuddy-dbup:latest
MB_MGMT_API_IMAGE=ghcr.io/d4m13n-d3v/mechanicbuddy-management-api:latest
MB_MGMT_PORTAL_IMAGE=ghcr.io/d4m13n-d3v/mechanicbuddy-management-portal:latest
MB_MGMT_DBUP_IMAGE=ghcr.io/d4m13n-d3v/mechanicbuddy-management-dbup:latest
COMMISSIONS_API_IMAGE=ghcr.io/d4m13n-d3v/comissions-api-amd64:latest
COMMISSIONS_UI_IMAGE=ghcr.io/d4m13n-d3v/comissions-app-ui:latest
